{
  "name": "@gabrielvfonseca/anthropic-vertex-provider",
  "version": "2026.7.2",
  "description": "Operator Anthropic Vertex provider plugin for Claude models on Google Vertex AI.",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielvfonseca/operator"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "0.19.0"
  },
  "devDependencies": {
    "@operator/plugin-sdk": "workspace:*",
    "@operator/typescript-config": "workspace:*"
  },
  "@gabrielvfonseca/operator": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@gabrielvfonseca/anthropic-vertex-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.12-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
