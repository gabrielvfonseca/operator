{
  "name": "@gabrielvfonseca/mattermost",
  "version": "2026.7.2",
  "description": "Operator Mattermost channel plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielvfonseca/operator"
  },
  "type": "module",
  "dependencies": {
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@gabrielvfonseca/plugin-sdk": "workspace:*",
    "@gabrielvfonseca/operator": "workspace:*"
  },
  "peerDependencies": {
    "@gabrielvfonseca/operator": ">=2026.7.2"
  },
  "peerDependenciesMeta": {
    "@gabrielvfonseca/operator": {
      "optional": true
    }
  },
  "@gabrielvfonseca/operator": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "mattermost",
      "label": "Mattermost",
      "selectionLabel": "Mattermost (plugin)",
      "docsPath": "/channels/mattermost",
      "docsLabel": "mattermost",
      "blurb": "self-hosted Slack-style chat; install the plugin to enable.",
      "order": 65
    },
    "install": {
      "clawhubSpec": "clawhub:@gabrielvfonseca/mattermost",
      "npmSpec": "@gabrielvfonseca/mattermost",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.9",
      "allowInvalidConfigRecovery": true
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
