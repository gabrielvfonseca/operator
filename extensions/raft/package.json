{
  "name": "@gabrielvfonseca/raft",
  "version": "2026.7.2",
  "description": "Operator Raft channel plugin for Raft CLI wake bridges.",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielvfonseca/operator"
  },
  "type": "module",
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@gabrielvfonseca/plugin-sdk": "workspace:*",
    "@gabrielvfonseca/operator": "workspace:*"
  },
  "peerDependencies": {
    "@gabrielvfonseca/operator": ">=2026.7.2"
  },
  "peerDependenciesMeta": {
    "@gabrielvfonseca/operator": {
      "optional": true
    }
  },
  "@gabrielvfonseca/operator": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "install": {
      "npmSpec": "@gabrielvfonseca/raft",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.8"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2"
    },
    "channel": {
      "id": "raft",
      "label": "Raft",
      "selectionLabel": "Raft (CLI wake bridge)",
      "docsPath": "/channels/raft",
      "docsLabel": "raft",
      "blurb": "Raft CLI wake bridge for human and agent collaboration.",
      "order": 72
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
