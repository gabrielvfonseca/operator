{
  "name": "@gabrielvfonseca/openshell-sandbox",
  "version": "2026.7.2",
  "description": "Operator sandbox backend for the NVIDIA OpenShell CLI with mirrored local workspaces and SSH command execution.",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielvfonseca/operator"
  },
  "type": "module",
  "dependencies": {
    "p-limit": "7.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@operator/plugin-sdk": "workspace:*"
  },
  "@gabrielvfonseca/operator": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@gabrielvfonseca/openshell-sandbox",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.12-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
