{
  "name": "@gabrielvfonseca/cohere-provider",
  "version": "2026.7.2",
  "description": "Operator Cohere provider plugin.",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielvfonseca/operator"
  },
  "type": "module",
  "devDependencies": {
    "@operator/plugin-sdk": "workspace:*"
  },
  "@gabrielvfonseca/operator": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@gabrielvfonseca/cohere-provider",
      "npmSpec": "@gabrielvfonseca/cohere-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.8"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2",
      "bundledDist": true
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
