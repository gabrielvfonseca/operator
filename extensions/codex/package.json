{
  "name": "@gabrielvfonseca/codex",
  "version": "2026.7.2",
  "description": "Operator Codex app-server harness, model provider, and native session supervision plugin.",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielvfonseca/operator"
  },
  "type": "module",
  "dependencies": {
    "@openai/codex": "0.144.4",
    "semver": "7.8.5",
    "smol-toml": "1.7.0",
    "typebox": "1.3.3",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@operator/plugin-sdk": "workspace:*"
  },
  "@gabrielvfonseca/operator": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@gabrielvfonseca/codex",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.1-beta.1",
      "requiredPlatformPackages": [
        "@openai/codex-linux-x64",
        "@openai/codex-linux-arm64",
        "@openai/codex-darwin-x64",
        "@openai/codex-darwin-arm64",
        "@openai/codex-win32-x64",
        "@openai/codex-win32-arm64"
      ]
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true,
      "requireLatestDependencies": [
        "@openai/codex"
      ],
      "bundleRuntimeDependencies": false
    }
  }
}
