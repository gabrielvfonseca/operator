{
  "name": "@gabrielvfonseca/copilot",
  "version": "2026.7.2",
  "description": "Operator GitHub Copilot agent runtime plugin (registers a `github-copilot` AgentHarness backed by @github/copilot-sdk over JSON-RPC to the GitHub Copilot CLI)",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielvfonseca/operator"
  },
  "type": "module",
  "dependencies": {
    "@github/copilot-sdk": "1.0.5"
  },
  "devDependencies": {
    "@operator/plugin-sdk": "workspace:*",
    "@operator/typescript-config": "workspace:*"
  },
  "@gabrielvfonseca/operator": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@gabrielvfonseca/copilot",
      "npmSpec": "@gabrielvfonseca/copilot",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.28"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2",
      "bundledDist": false
    },
    "release": {
      "bundleRuntimeDependencies": false,
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
