{
  "name": "@gabrielvfonseca/lobster",
  "version": "2026.7.2",
  "description": "Lobster workflow tool plugin for typed pipelines and resumable approvals.",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielvfonseca/operator"
  },
  "type": "module",
  "dependencies": {
    "@clawdbot/lobster": "2026.6.11",
    "typebox": "1.3.3"
  },
  "devDependencies": {
    "@gabrielvfonseca/plugin-sdk": "workspace:*"
  },
  "@gabrielvfonseca/operator": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@gabrielvfonseca/lobster",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.25"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
