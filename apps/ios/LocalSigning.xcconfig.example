// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

OPERATOR_CODE_SIGN_STYLE = Automatic
OPERATOR_CODE_SIGN_IDENTITY = Apple Development
OPERATOR_DEVELOPMENT_TEAM = YOUR_TEAM_ID

OPERATOR_APP_BUNDLE_ID = ai.operatorfoundation.app
OPERATOR_SHARE_BUNDLE_ID = ai.operatorfoundation.app.share
OPERATOR_APP_GROUP_ID = group.ai.operatorfoundation.app.shared
OPERATOR_ACTIVITY_WIDGET_BUNDLE_ID = ai.operatorfoundation.app.activitywidget
OPERATOR_WATCH_APP_BUNDLE_ID = ai.operatorfoundation.app.watchkitapp

// Leave empty with automatic signing.
OPERATOR_APP_PROFILE =
OPERATOR_SHARE_PROFILE =
OPERATOR_ACTIVITY_WIDGET_PROFILE =
OPERATOR_WATCH_APP_PROFILE =
