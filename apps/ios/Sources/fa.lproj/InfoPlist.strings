"CFBundleDisplayName" = "$(OPERATOR_APP_DISPLAY_NAME)";
/* Operator source: "Operator uses your calendars to show events and scheduling context when you enable calendar access." */
"NSCalendarsFullAccessUsageDescription" = "Operator از تقویم‌های شما استفاده می‌کند تا وقتی دسترسی به تقویم را فعال می‌کنید، رویدادها و زمینهٔ زمان‌بندی را نشان دهد.";
/* Operator source: "Operator uses your calendars to show events and scheduling context when you enable calendar access." */
"NSCalendarsUsageDescription" = "Operator از تقویم‌های شما استفاده می‌کند تا وقتی دسترسی به تقویم را فعال می‌کنید، رویدادها و زمینهٔ زمان‌بندی را نشان دهد.";
/* Operator source: "Operator uses your calendars to add events when you enable calendar access." */
"NSCalendarsWriteOnlyAccessUsageDescription" = "Operator از تقویم‌های شما استفاده می‌کند تا وقتی دسترسی به تقویم را فعال می‌کنید، رویدادها را اضافه کند.";
/* Operator source: "Operator uses the camera when you scan a Gateway setup QR code or ask your paired Gateway or assistant to capture a photo or short video from this iPhone, for example to connect to your Gateway or show your assistant a document, device screen, or workspace." */
"NSCameraUsageDescription" = "Operator زمانی از دوربین استفاده می‌کند که کد QR راه‌اندازی Gateway را اسکن می‌کنید یا از Gateway جفت‌شده یا دستیار خود می‌خواهید از این iPhone عکس یا ویدیوی کوتاهی بگیرد؛ برای مثال برای اتصال به Gateway یا نشان دادن یک سند، صفحهٔ دستگاه یا فضای کاری به دستیار خود.";
/* Operator source: "Operator uses your contacts so you can search and reference people while using the assistant." */
"NSContactsUsageDescription" = "Operator از مخاطبان شما استفاده می‌کند تا هنگام استفاده از دستیار بتوانید افراد را جست‌وجو کرده و به آن‌ها ارجاع دهید.";
/* Operator source: "Operator discovers and connects to your Operator gateway on the local network." */
"NSLocalNetworkUsageDescription" = "Operator، gateway ‏Operator شما را در شبکهٔ محلی پیدا می‌کند و به آن متصل می‌شود.";
/* Operator source: "Operator can share your location in the background when you enable Always." */
"NSLocationAlwaysAndWhenInUseUsageDescription" = "Operator می‌تواند وقتی گزینهٔ Always را فعال می‌کنید، موقعیت مکانی شما را در پس‌زمینه به اشتراک بگذارد.";
/* Operator source: "Operator uses your location when you allow location sharing." */
"NSLocationWhenInUseUsageDescription" = "Operator وقتی اشتراک‌گذاری موقعیت مکانی را مجاز می‌کنید، از موقعیت مکانی شما استفاده می‌کند.";
/* Operator source: "Operator uses the microphone for realtime chat, voice wake, push-to-talk, and voice notes." */
"NSMicrophoneUsageDescription" = "Operator از میکروفون برای گفت‌وگوی بی‌درنگ، فعال‌سازی صوتی، فشار برای صحبت و یادداشت‌های صوتی استفاده می‌کند.";
/* Operator source: "Operator may use motion data to support device-aware interactions and automations." */
"NSMotionUsageDescription" = "Operator ممکن است از داده‌های حرکت برای پشتیبانی از تعاملات و خودکارسازی‌های آگاه از دستگاه استفاده کند.";
/* Operator source: "After you enable Health Summaries, Operator reads steps, sleep, resting heart rate, and workouts to share requested aggregates with your configured AI provider." */
"NSHealthShareUsageDescription" = "پس از فعال‌کردن خلاصه‌های سلامت، Operator گام‌ها، خواب، ضربان قلب در حالت استراحت و تمرین‌ها را می‌خواند تا داده‌های تجمیعی درخواستی را با ارائه‌دهنده هوش مصنوعی پیکربندی‌شده شما به اشتراک بگذارد.";
/* Operator source: "Operator does not write or change Health data. Health Summaries read steps, sleep, resting heart rate, and workouts to share requested aggregates with your configured AI provider." */
"NSHealthUpdateUsageDescription" = "Operator داده‌های Health را نمی‌نویسد یا تغییر نمی‌دهد. Health Summaries گام‌ها، خواب، ضربان قلب در حالت استراحت و تمرین‌ها را می‌خواند تا مجموعه‌های درخواستی را با ارائه‌دهنده AI پیکربندی‌شده‌تان به اشتراک بگذارد.";
/* Operator source: "Operator lets your assistant read photos you allow and lets you choose photos to share." */
"NSPhotoLibraryUsageDescription" = "Operator به دستیار شما اجازه می‌دهد عکس‌هایی را که مجاز می‌کنید بخواند و به شما امکان می‌دهد عکس‌هایی را برای اشتراک‌گذاری انتخاب کنید.";
/* Operator source: "Operator uses your reminders to list, add, and complete tasks when you enable reminders access." */
"NSRemindersFullAccessUsageDescription" = "وقتی دسترسی به یادآورها را فعال می‌کنید، Operator از یادآورهای شما برای فهرست کردن، افزودن و تکمیل کارها استفاده می‌کند.";
/* Operator source: "Operator uses on-device speech recognition for talk mode and voice wake." */
"NSSpeechRecognitionUsageDescription" = "Operator برای حالت گفت‌وگو و بیدارباش صوتی از تشخیص گفتار روی دستگاه استفاده می‌کند.";
