"CFBundleDisplayName" = "$(OPERATOR_APP_DISPLAY_NAME)";
/* Operator source: "Operator uses your calendars to show events and scheduling context when you enable calendar access." */
"NSCalendarsFullAccessUsageDescription" = "Operator verwendet Ihre Kalender, um Ereignisse und Planungskontext anzuzeigen, wenn Sie den Kalenderzugriff aktivieren.";
/* Operator source: "Operator uses your calendars to show events and scheduling context when you enable calendar access." */
"NSCalendarsUsageDescription" = "Operator verwendet Ihre Kalender, um Ereignisse und Planungskontext anzuzeigen, wenn Sie den Kalenderzugriff aktivieren.";
/* Operator source: "Operator uses your calendars to add events when you enable calendar access." */
"NSCalendarsWriteOnlyAccessUsageDescription" = "Operator verwendet Ihre Kalender, um Ereignisse hinzuzufügen, wenn Sie den Kalenderzugriff aktivieren.";
/* Operator source: "Operator uses the camera when you scan a Gateway setup QR code or ask your paired Gateway or assistant to capture a photo or short video from this iPhone, for example to connect to your Gateway or show your assistant a document, device screen, or workspace." */
"NSCameraUsageDescription" = "Operator verwendet die Kamera, wenn Sie einen QR-Code zur Gateway-Einrichtung scannen oder Ihre gekoppelte Gateway oder Ihren Assistenten bitten, ein Foto oder kurzes Video von diesem iPhone aufzunehmen, beispielsweise um eine Verbindung zu Ihrer Gateway herzustellen oder Ihrem Assistenten ein Dokument, einen Gerätebildschirm oder einen Arbeitsbereich zu zeigen.";
/* Operator source: "Operator uses your contacts so you can search and reference people while using the assistant." */
"NSContactsUsageDescription" = "Operator verwendet Ihre Kontakte, damit Sie Personen suchen und referenzieren können, während Sie den Assistenten verwenden.";
/* Operator source: "Operator discovers and connects to your Operator gateway on the local network." */
"NSLocalNetworkUsageDescription" = "Operator erkennt Ihre Operator-Gateway im lokalen Netzwerk und stellt eine Verbindung zu ihr her.";
/* Operator source: "Operator can share your location in the background when you enable Always." */
"NSLocationAlwaysAndWhenInUseUsageDescription" = "Operator kann Ihren Standort im Hintergrund teilen, wenn Sie „Immer“ aktivieren.";
/* Operator source: "Operator uses your location when you allow location sharing." */
"NSLocationWhenInUseUsageDescription" = "Operator verwendet Ihren Standort, wenn Sie die Standortfreigabe erlauben.";
/* Operator source: "Operator uses the microphone for realtime chat, voice wake, push-to-talk, and voice notes." */
"NSMicrophoneUsageDescription" = "Operator verwendet das Mikrofon für Echtzeit-Chat, Sprachaktivierung, Push-to-Talk und Sprachnotizen.";
/* Operator source: "Operator may use motion data to support device-aware interactions and automations." */
"NSMotionUsageDescription" = "Operator kann Bewegungsdaten verwenden, um gerätebewusste Interaktionen und Automatisierungen zu unterstützen.";
/* Operator source: "After you enable Health Summaries, Operator reads steps, sleep, resting heart rate, and workouts to share requested aggregates with your configured AI provider." */
"NSHealthShareUsageDescription" = "Nachdem du Gesundheitszusammenfassungen aktiviert hast, liest Operator Schritte, Schlaf, Ruhepuls und Trainings, um angeforderte aggregierte Daten mit deinem konfigurierten KI-Anbieter zu teilen.";
/* Operator source: "Operator does not write or change Health data. Health Summaries read steps, sleep, resting heart rate, and workouts to share requested aggregates with your configured AI provider." */
"NSHealthUpdateUsageDescription" = "Operator schreibt oder ändert keine Gesundheitsdaten. Gesundheitsübersichten lesen Schritte, Schlaf, Ruhepuls und Workouts, um angeforderte Zusammenfassungen mit Ihrem konfigurierten KI-Anbieter zu teilen.";
/* Operator source: "Operator lets your assistant read photos you allow and lets you choose photos to share." */
"NSPhotoLibraryUsageDescription" = "Operator ermöglicht deinem Assistenten, von dir erlaubte Fotos zu lesen, und lässt dich Fotos zum Teilen auswählen.";
/* Operator source: "Operator uses your reminders to list, add, and complete tasks when you enable reminders access." */
"NSRemindersFullAccessUsageDescription" = "Operator verwendet deine Erinnerungen, um Aufgaben aufzulisten, hinzuzufügen und abzuschließen, wenn du den Zugriff auf Erinnerungen aktivierst.";
/* Operator source: "Operator uses on-device speech recognition for talk mode and voice wake." */
"NSSpeechRecognitionUsageDescription" = "Operator verwendet die Spracherkennung auf dem Gerät für den Sprechmodus und die Sprachaktivierung.";
