"CFBundleDisplayName" = "$(OPERATOR_APP_DISPLAY_NAME)";
/* Operator source: "Operator uses your calendars to show events and scheduling context when you enable calendar access." */
"NSCalendarsFullAccessUsageDescription" = "Operator, takvim erişimini etkinleştirdiğinizde etkinlikleri ve planlama bağlamını göstermek için takvimlerinizi kullanır.";
/* Operator source: "Operator uses your calendars to show events and scheduling context when you enable calendar access." */
"NSCalendarsUsageDescription" = "Operator, takvim erişimini etkinleştirdiğinizde etkinlikleri ve planlama bağlamını göstermek için takvimlerinizi kullanır.";
/* Operator source: "Operator uses your calendars to add events when you enable calendar access." */
"NSCalendarsWriteOnlyAccessUsageDescription" = "Operator, takvim erişimini etkinleştirdiğinizde etkinlik eklemek için takvimlerinizi kullanır.";
/* Operator source: "Operator uses the camera when you scan a Gateway setup QR code or ask your paired Gateway or assistant to capture a photo or short video from this iPhone, for example to connect to your Gateway or show your assistant a document, device screen, or workspace." */
"NSCameraUsageDescription" = "Operator, bir Gateway kurulum QR kodunu taradığınızda veya eşleştirilmiş Gateway'inizden ya da asistanınızdan bu iPhone'dan fotoğraf veya kısa video çekmesini istediğinizde kamerayı kullanır; örneğin Gateway'inize bağlanmak veya asistanınıza bir belge, cihaz ekranı ya da çalışma alanı göstermek için.";
/* Operator source: "Operator uses your contacts so you can search and reference people while using the assistant." */
"NSContactsUsageDescription" = "Operator, asistanı kullanırken kişileri arayabilmeniz ve onlara referans verebilmeniz için kişilerinizi kullanır.";
/* Operator source: "Operator discovers and connects to your Operator gateway on the local network." */
"NSLocalNetworkUsageDescription" = "Operator, yerel ağdaki Operator gateway'inizi keşfeder ve ona bağlanır.";
/* Operator source: "Operator can share your location in the background when you enable Always." */
"NSLocationAlwaysAndWhenInUseUsageDescription" = "Operator, Her Zaman seçeneğini etkinleştirdiğinizde konumunuzu arka planda paylaşabilir.";
/* Operator source: "Operator uses your location when you allow location sharing." */
"NSLocationWhenInUseUsageDescription" = "Operator, konum paylaşımına izin verdiğinizde konumunuzu kullanır.";
/* Operator source: "Operator uses the microphone for realtime chat, voice wake, push-to-talk, and voice notes." */
"NSMicrophoneUsageDescription" = "Operator mikrofonu gerçek zamanlı sohbet, sesle uyandırma, bas-konuş ve sesli notlar için kullanır.";
/* Operator source: "Operator may use motion data to support device-aware interactions and automations." */
"NSMotionUsageDescription" = "Operator, cihaza duyarlı etkileşimleri ve otomasyonları desteklemek için hareket verilerini kullanabilir.";
/* Operator source: "After you enable Health Summaries, Operator reads steps, sleep, resting heart rate, and workouts to share requested aggregates with your configured AI provider." */
"NSHealthShareUsageDescription" = "Sağlık Özetleri'ni etkinleştirdikten sonra Operator, istenen toplu verileri yapılandırdığınız yapay zeka sağlayıcısıyla paylaşmak için adımları, uykuyu, dinlenme kalp atış hızını ve antrenmanları okur.";
/* Operator source: "Operator does not write or change Health data. Health Summaries read steps, sleep, resting heart rate, and workouts to share requested aggregates with your configured AI provider." */
"NSHealthUpdateUsageDescription" = "Operator, Sağlık verilerini yazmaz veya değiştirmez. Sağlık Özetleri; adımları, uykuyu, dinlenme kalp atış hızını ve antrenmanları okuyarak istenen toplu verileri yapılandırdığınız yapay zeka sağlayıcısıyla paylaşır.";
/* Operator source: "Operator lets your assistant read photos you allow and lets you choose photos to share." */
"NSPhotoLibraryUsageDescription" = "Operator, asistanınızın izin verdiğiniz fotoğrafları okumasını sağlar ve paylaşılacak fotoğrafları seçmenize olanak tanır.";
/* Operator source: "Operator uses your reminders to list, add, and complete tasks when you enable reminders access." */
"NSRemindersFullAccessUsageDescription" = "Operator, anımsatıcılara erişimi etkinleştirdiğinizde görevleri listelemek, eklemek ve tamamlamak için anımsatıcılarınızı kullanır.";
/* Operator source: "Operator uses on-device speech recognition for talk mode and voice wake." */
"NSSpeechRecognitionUsageDescription" = "Operator, konuşma modu ve sesle uyandırma için aygıt üzerinde konuşma tanımayı kullanır.";
