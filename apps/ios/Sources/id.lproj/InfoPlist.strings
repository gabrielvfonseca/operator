"CFBundleDisplayName" = "$(OPERATOR_APP_DISPLAY_NAME)";
/* Operator source: "Operator uses your calendars to show events and scheduling context when you enable calendar access." */
"NSCalendarsFullAccessUsageDescription" = "Operator menggunakan kalender Anda untuk menampilkan acara dan konteks penjadwalan saat Anda mengaktifkan akses kalender.";
/* Operator source: "Operator uses your calendars to show events and scheduling context when you enable calendar access." */
"NSCalendarsUsageDescription" = "Operator menggunakan kalender Anda untuk menampilkan acara dan konteks penjadwalan saat Anda mengaktifkan akses kalender.";
/* Operator source: "Operator uses your calendars to add events when you enable calendar access." */
"NSCalendarsWriteOnlyAccessUsageDescription" = "Operator menggunakan kalender Anda untuk menambahkan acara saat Anda mengaktifkan akses kalender.";
/* Operator source: "Operator uses the camera when you scan a Gateway setup QR code or ask your paired Gateway or assistant to capture a photo or short video from this iPhone, for example to connect to your Gateway or show your assistant a document, device screen, or workspace." */
"NSCameraUsageDescription" = "Operator menggunakan kamera saat Anda memindai kode QR penyiapan Gateway atau meminta Gateway yang dipasangkan atau asisten Anda untuk mengambil foto atau video pendek dari iPhone ini, misalnya untuk terhubung ke Gateway Anda atau menunjukkan dokumen, layar perangkat, atau ruang kerja kepada asisten Anda.";
/* Operator source: "Operator uses your contacts so you can search and reference people while using the assistant." */
"NSContactsUsageDescription" = "Operator menggunakan kontak Anda agar Anda dapat mencari dan merujuk orang saat menggunakan asisten.";
/* Operator source: "Operator discovers and connects to your Operator gateway on the local network." */
"NSLocalNetworkUsageDescription" = "Operator menemukan dan terhubung ke gateway Operator Anda di jaringan lokal.";
/* Operator source: "Operator can share your location in the background when you enable Always." */
"NSLocationAlwaysAndWhenInUseUsageDescription" = "Operator dapat membagikan lokasi Anda di latar belakang saat Anda mengaktifkan Selalu.";
/* Operator source: "Operator uses your location when you allow location sharing." */
"NSLocationWhenInUseUsageDescription" = "Operator menggunakan lokasi Anda saat Anda mengizinkan berbagi lokasi.";
/* Operator source: "Operator uses the microphone for realtime chat, voice wake, push-to-talk, and voice notes." */
"NSMicrophoneUsageDescription" = "Operator menggunakan mikrofon untuk obrolan realtime, voice wake, push-to-talk, dan pesan suara.";
/* Operator source: "Operator may use motion data to support device-aware interactions and automations." */
"NSMotionUsageDescription" = "Operator dapat menggunakan data gerak untuk mendukung interaksi dan automasi yang sadar perangkat.";
/* Operator source: "After you enable Health Summaries, Operator reads steps, sleep, resting heart rate, and workouts to share requested aggregates with your configured AI provider." */
"NSHealthShareUsageDescription" = "Setelah Anda mengaktifkan Ringkasan Kesehatan, Operator membaca langkah, tidur, detak jantung saat istirahat, dan olahraga untuk membagikan data agregat yang diminta kepada penyedia AI yang Anda konfigurasikan.";
/* Operator source: "Operator does not write or change Health data. Health Summaries read steps, sleep, resting heart rate, and workouts to share requested aggregates with your configured AI provider." */
"NSHealthUpdateUsageDescription" = "Operator tidak menulis atau mengubah data Health. Health Summaries membaca langkah, tidur, detak jantung istirahat, dan latihan untuk membagikan agregat yang diminta ke penyedia AI yang Anda konfigurasikan.";
/* Operator source: "Operator lets your assistant read photos you allow and lets you choose photos to share." */
"NSPhotoLibraryUsageDescription" = "Operator memungkinkan asisten Anda membaca foto yang Anda izinkan dan memungkinkan Anda memilih foto untuk dibagikan.";
/* Operator source: "Operator uses your reminders to list, add, and complete tasks when you enable reminders access." */
"NSRemindersFullAccessUsageDescription" = "Operator menggunakan pengingat Anda untuk mencantumkan, menambahkan, dan menyelesaikan tugas saat Anda mengaktifkan akses pengingat.";
/* Operator source: "Operator uses on-device speech recognition for talk mode and voice wake." */
"NSSpeechRecognitionUsageDescription" = "Operator menggunakan pengenalan ucapan di perangkat untuk mode bicara dan bangun dengan suara.";
