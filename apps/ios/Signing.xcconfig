// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

#include "build/Version.xcconfig"

OPERATOR_CODE_SIGN_STYLE = Manual
OPERATOR_CODE_SIGN_IDENTITY = Apple Development
OPERATOR_CODE_SIGN_ENTITLEMENTS = Sources/Operator.entitlements
OPERATOR_DEVELOPMENT_TEAM = FWJYW4S8P8

OPERATOR_APP_BUNDLE_ID = ai.operatorfoundation.app
OPERATOR_SHARE_BUNDLE_ID = ai.operatorfoundation.app.share
OPERATOR_APP_GROUP_ID = group.ai.operatorfoundation.app.shared
OPERATOR_WATCH_APP_BUNDLE_ID = ai.operatorfoundation.app.watchkitapp
OPERATOR_ACTIVITY_WIDGET_BUNDLE_ID = ai.operatorfoundation.app.activitywidget
OPERATOR_APNS_ENTITLEMENT_ENVIRONMENT = development

OPERATOR_APP_PROFILE = ai.operatorfoundation.app Development
OPERATOR_SHARE_PROFILE = ai.operatorfoundation.app.share Development
OPERATOR_ACTIVITY_WIDGET_PROFILE =
OPERATOR_WATCH_APP_PROFILE =

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"

// Debug products install alongside release products and keep their app-group data separate.
OPERATOR_DEBUG_APP_BUNDLE_ID = $(OPERATOR_APP_BUNDLE_ID).debug
OPERATOR_DEBUG_SHARE_BUNDLE_ID = $(OPERATOR_DEBUG_APP_BUNDLE_ID).share
OPERATOR_DEBUG_ACTIVITY_WIDGET_BUNDLE_ID = $(OPERATOR_DEBUG_APP_BUNDLE_ID).activitywidget
OPERATOR_DEBUG_WATCH_APP_BUNDLE_ID = $(OPERATOR_DEBUG_APP_BUNDLE_ID).watchkitapp
OPERATOR_DEBUG_APP_GROUP_ID = $(OPERATOR_APP_GROUP_ID).debug
